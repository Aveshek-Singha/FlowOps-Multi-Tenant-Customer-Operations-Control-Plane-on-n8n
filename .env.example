# ---- Secrets never committed. Real values live in each person's local .env. ----

# ============ N8N (Oracle VM .env, Lead only) ============
N8N_HOST=
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=
N8N_ENCRYPTION_KEY=
# Queue mode
EXECUTIONS_MODE=queue
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
# Metrics (Contract E)
N8N_METRICS=true
# Code nodes need Node's crypto module for Stripe HMAC verification
NODE_FUNCTION_ALLOW_BUILTIN=crypto

# ============ SUPABASE ============
# Lead uses SERVICE_KEY in n8n; Teammate uses ANON_KEY in the browser only
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ============ TELEGRAM (Contract: HITL approvals) ============
TELEGRAM_BOT_TOKEN=
# Chat id that receives HITL approval + CSM notifications (Contract B onboarding)
TELEGRAM_CHAT_ID=
# Optional second approver/escalation chat; falls back to TELEGRAM_CHAT_ID when blank
TELEGRAM_ESCALATION_CHAT_ID=
FLOWOPS_SECOND_APPROVER=ops-lead
APPROVAL_REMINDER_AFTER_MINUTES=30
APPROVAL_ESCALATION_AFTER_MINUTES=120
APPROVAL_REMINDER_REPEAT_MINUTES=60

# ============ STRIPE — test mode, Lead only (Contract F) ============
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# ============ GITHUB (Issues API = ticket system) ============
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_SLA_LABEL=sla-watch
GITHUB_SLA_HOURS=48

# ============ SERVICE 6/7/11 DEFAULTS ============
HEALTH_RISK_THRESHOLD=70
RENEWAL_WINDOW_DAYS=45
COMPLIANCE_RETENTION_DAYS=365

# ============ GRAFANA CLOUD — Teammate only ============
GRAFANA_CLOUD_PROM_URL=
GRAFANA_CLOUD_PROM_USER=
GRAFANA_CLOUD_PROM_KEY=
GRAFANA_CLOUD_LOKI_URL=
GRAFANA_CLOUD_LOKI_USER=
GRAFANA_CLOUD_LOKI_KEY=
