n8n-data/
*.sqlite
*.sqlite-journal

# ── Node / Next.js (frontend) ───────────────────────────────────────
node_modules/
.next/
out/
build/
dist/
.vercel/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

