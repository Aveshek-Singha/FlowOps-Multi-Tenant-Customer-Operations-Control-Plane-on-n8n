# Copy to `.env` (gitignored) and fill in. Compose auto-loads `.env` from this dir.

# --- n8n internal DB (local postgres container) ---
N8N_DB_NAME=n8n
N8N_DB_USER=n8n
N8N_DB_PASSWORD=CHANGE_ME_strong_password

# --- n8n encryption key (NEVER rotate mid-project; losing it = lost credentials) ---
# Generate: openssl rand -hex 24
N8N_ENCRYPTION_KEY=CHANGE_ME_run_openssl_rand_hex_24

# --- ngrok public URL (start ngrok FIRST, paste the https URL here) ---
# e.g. https://abcd-1-2-3-4.ngrok-free.app  (changes on every ngrok restart)
WEBHOOK_URL=https://CHANGE_ME.ngrok-free.app

GENERIC_TIMEZONE=UTC
NODE_FUNCTION_ALLOW_BUILTIN=crypto

# --- Supabase app data (FlowOps workflows) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Telegram notifications / HITL ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ESCALATION_CHAT_ID=
FLOWOPS_SECOND_APPROVER=ops-lead
APPROVAL_REMINDER_AFTER_MINUTES=30
APPROVAL_ESCALATION_AFTER_MINUTES=120
APPROVAL_REMINDER_REPEAT_MINUTES=60

# --- Stripe webhook signature verification ---
# Use Stripe CLI/dashboard endpoint secret for /webhook/stripe-onboarding and /webhook/stripe-dunning.
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# --- GitHub Issues SLA scanner (Service 4) ---
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_SLA_LABEL=sla-watch
GITHUB_SLA_HOURS=48

# --- Service 6/7/11 defaults ---
HEALTH_RISK_THRESHOLD=70
RENEWAL_WINDOW_DAYS=45
COMPLIANCE_RETENTION_DAYS=365
